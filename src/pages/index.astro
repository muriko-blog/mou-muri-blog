---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { categoryList } from '../utils/categories';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latest = posts.slice(0, 6);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-text">
					<p class="hero-eyebrow">共働き子育て世帯のための時短課金レビュー</p>
					<h1>もう無理。を、<br class="sp-only" />お金で解決する。</h1>
					<p class="hero-lead">
						仕事も家事も育児も全部。そんな毎日に「お金で時間を買う」サービスを、
						元・限界共働きの<strong>むりこ</strong>が本音でレビューします。
					</p>
					<div class="hero-actions">
						<a href="/blog" class="btn">レビューを読む</a>
						<a href="/about" class="hero-link">むりこって誰？ →</a>
					</div>
				</div>
				<div class="hero-figure">
					<div class="hero-bubble">
						<p>こんにちは、<strong>むりこ</strong>です！<br />共働きで疲れてた私を救ってくれた時短サービス、本音でレビューしてます🌿</p>
					</div>
					<img src="/muriko.svg" alt="むりこ" class="hero-avatar" />
				</div>
			</section>

			<section class="cats">
				<h2 class="section-title">カテゴリーから探す</h2>
				<div class="cat-grid">
					{
						categoryList.map((c) => (
							<a
								href="/blog"
								class="cat-card"
								style={`--cat-color:${c.color}; --cat-soft:${c.soft}`}
							>
								<span class="cat-icon">{c.icon}</span>
								<span class="cat-name">{c.name}</span>
								<span class="cat-desc">{c.desc}</span>
							</a>
						))
					}
				</div>
			</section>

			<section class="latest">
				<h2 class="section-title">新着レビュー</h2>
				{
					latest.length === 0 ? (
						<div class="empty">
							<p>📝 ただいま最初のレビューを準備中です。</p>
							<p class="empty-sub">近日公開予定。お楽しみに！</p>
						</div>
					) : (
						<div class="post-grid">
							{latest.map((post) => (
								<a href={`/blog/${post.id}/`} class="post-card">
									{post.data.heroImage && (
										<div class="post-thumb">
											<Image width={600} height={340} src={post.data.heroImage} alt="" />
											{post.data.category && (
												<div class="post-thumb-badge">
													<CategoryBadge slug={post.data.category} />
												</div>
											)}
										</div>
									)}
									<div class="post-body">
										<p class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h3 class="post-title">{post.data.title}</h3>
										<p class="post-desc">{post.data.description}</p>
									</div>
								</a>
							))}
						</div>
					)
				}
			</section>
		</main>
		<Footer />
	</body>

	<style>
		/* ヒーロー */
		.hero {
			display: grid;
			grid-template-columns: 1.3fr 1fr;
			gap: 1.5em;
			align-items: center;
			padding: 2em 1.5em;
			background: linear-gradient(160deg, #fff3df 0%, var(--accent-soft) 100%);
			border-radius: var(--radius);
			margin-bottom: 3em;
		}
		.hero-eyebrow {
			display: inline-block;
			background: #fff;
			color: var(--accent-dark);
			font-weight: 700;
			font-size: 0.85rem;
			padding: 0.4em 1.1em;
			border-radius: 999px;
			margin: 0 0 1em;
			box-shadow: var(--box-shadow);
		}
		.hero h1 {
			font-size: 2.4rem;
			letter-spacing: 0.02em;
			margin-bottom: 0.5em;
		}
		.hero-lead {
			max-width: 540px;
			margin: 0 0 1.6em;
			color: rgb(var(--gray-dark));
		}
		.hero-actions {
			display: flex;
			align-items: center;
			gap: 1.4em;
			flex-wrap: wrap;
		}
		.hero-link {
			font-weight: 700;
			color: var(--accent-dark);
		}
		.hero-figure {
			position: relative;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1em;
		}
		.hero-bubble {
			position: relative;
			background: #fff;
			border: 2px solid var(--accent);
			border-radius: 18px;
			padding: 0.9em 1.1em;
			max-width: 260px;
			box-shadow: var(--box-shadow);
			font-size: 0.95rem;
		}
		.hero-bubble p {
			margin: 0;
			line-height: 1.6;
		}
		.hero-bubble::after {
			content: '';
			position: absolute;
			left: 50%;
			bottom: -14px;
			transform: translateX(-50%);
			border: 8px solid transparent;
			border-top-color: var(--accent);
		}
		.hero-bubble::before {
			content: '';
			position: absolute;
			left: 50%;
			bottom: -10px;
			transform: translateX(-50%);
			border: 7px solid transparent;
			border-top-color: #fff;
			z-index: 1;
		}
		.hero-avatar {
			width: 200px;
			height: 200px;
			border-radius: 50%;
			border: 4px solid var(--accent);
			background: #fff;
		}

		/* セクション見出し */
		.section-title {
			position: relative;
			padding-left: 0.6em;
			margin-bottom: 1em;
			font-size: 1.45rem;
		}
		.section-title::before {
			content: "";
			position: absolute;
			left: 0;
			top: 0.15em;
			bottom: 0.15em;
			width: 5px;
			border-radius: 999px;
			background: var(--accent);
		}

		/* カテゴリーカード（色分け） */
		.cats {
			margin-bottom: 3em;
		}
		.cat-grid {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 1em;
		}
		.cat-card {
			display: flex;
			flex-direction: column;
			gap: 0.25em;
			padding: 1.4em 1.2em;
			background: var(--cat-soft);
			border: 1px solid var(--cat-color);
			border-top: 6px solid var(--cat-color);
			border-radius: var(--radius);
			text-decoration: none;
			color: rgb(var(--black));
			transition: transform 0.15s ease, box-shadow 0.15s ease;
		}
		.cat-card:hover {
			text-decoration: none;
			transform: translateY(-3px);
			box-shadow: var(--box-shadow-hover);
		}
		.cat-icon {
			font-size: 2rem;
		}
		.cat-name {
			font-weight: 800;
			font-size: 1.2rem;
			color: var(--cat-color);
		}
		.cat-desc {
			font-size: 0.85rem;
			color: rgb(var(--gray-dark));
			line-height: 1.5;
		}

		/* 新着記事グリッド */
		.post-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 1.5em;
		}
		.post-card {
			display: flex;
			flex-direction: column;
			background: var(--surface);
			border: 1px solid rgb(var(--gray-light));
			border-radius: var(--radius);
			overflow: hidden;
			text-decoration: none;
			color: rgb(var(--black));
			transition: transform 0.15s ease, box-shadow 0.15s ease;
		}
		.post-card:hover {
			text-decoration: none;
			transform: translateY(-3px);
			box-shadow: var(--box-shadow-hover);
		}
		.post-thumb {
			position: relative;
		}
		.post-thumb img {
			display: block;
			width: 100%;
			height: 180px;
			object-fit: cover;
			border-radius: 0;
		}
		.post-thumb-badge {
			position: absolute;
			top: 0.7em;
			left: 0.7em;
		}
		.post-body {
			padding: 1.1em 1.2em 1.4em;
		}
		.post-date {
			margin: 0 0 0.3em;
			font-size: 0.8rem;
			color: rgb(var(--gray));
		}
		.post-title {
			font-size: 1.15rem;
			margin: 0 0 0.4em;
			line-height: 1.4;
		}
		.post-desc {
			margin: 0;
			font-size: 0.9rem;
			color: rgb(var(--gray));
			line-height: 1.6;
		}

		/* 空状態 */
		.empty {
			text-align: center;
			padding: 2.5em 1em;
			background: var(--surface);
			border: 1px dashed rgb(var(--gray));
			border-radius: var(--radius);
			color: rgb(var(--gray-dark));
		}
		.empty p {
			margin: 0.2em 0;
			font-weight: 700;
		}
		.empty-sub {
			font-weight: 400 !important;
			color: rgb(var(--gray));
		}

		.sp-only {
			display: none;
		}

		@media (max-width: 860px) {
			.hero {
				grid-template-columns: 1fr;
				text-align: center;
			}
			.hero-actions {
				justify-content: center;
			}
			.hero-lead {
				margin-left: auto;
				margin-right: auto;
			}
			.cat-grid {
				grid-template-columns: repeat(2, 1fr);
			}
			.post-grid {
				grid-template-columns: repeat(2, 1fr);
			}
		}
		@media (max-width: 560px) {
			.hero h1 {
				font-size: 1.9rem;
			}
			.hero-avatar {
				width: 150px;
				height: 150px;
			}
			.sp-only {
				display: inline;
			}
			.post-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
</html>
