---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import CategoryBadge from '../../components/CategoryBadge.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`記事一覧｜${SITE_TITLE}`} description="共働き子育て世帯向けの時短課金レビュー記事一覧。" />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">記事一覧</h1>
			<p class="page-lead">時短サービス・時短家電・教育サービスの本音レビューをまとめています。</p>

			{
				posts.length === 0 ? (
					<div class="empty">
						<p>📝 ただいま最初のレビューを準備中です。</p>
						<p class="empty-sub">近日公開予定。お楽しみに！</p>
					</div>
				) : (
					<div class="post-grid">
						{posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-card">
								{post.data.heroImage && (
									<div class="post-thumb">
										<Image width={600} height={340} src={post.data.heroImage} alt="" />
										{post.data.category && (
											<div class="post-thumb-badge">
												<CategoryBadge slug={post.data.category} />
											</div>
										)}
									</div>
								)}
								<div class="post-body">
									<p class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-desc">{post.data.description}</p>
								</div>
							</a>
						))}
					</div>
				)
			}
		</main>
		<Footer />
	</body>

	<style>
		.page-title {
			text-align: center;
		}
		.page-lead {
			text-align: center;
			color: rgb(var(--gray));
			margin-bottom: 2.5em;
		}
		.post-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 1.5em;
		}
		.post-card {
			display: flex;
			flex-direction: column;
			background: var(--surface);
			border: 1px solid rgb(var(--gray-light));
			border-radius: var(--radius);
			overflow: hidden;
			text-decoration: none;
			color: rgb(var(--black));
			transition: transform 0.15s ease, box-shadow 0.15s ease;
		}
		.post-card:hover {
			text-decoration: none;
			transform: translateY(-3px);
			box-shadow: var(--box-shadow-hover);
		}
		.post-thumb {
			position: relative;
		}
		.post-thumb img {
			display: block;
			width: 100%;
			height: 180px;
			object-fit: cover;
			border-radius: 0;
		}
		.post-thumb-badge {
			position: absolute;
			top: 0.7em;
			left: 0.7em;
		}
		.post-body {
			padding: 1.1em 1.2em 1.4em;
		}
		.post-date {
			margin: 0 0 0.3em;
			font-size: 0.8rem;
			color: rgb(var(--gray));
		}
		.post-title {
			font-size: 1.15rem;
			margin: 0 0 0.4em;
			line-height: 1.4;
		}
		.post-desc {
			margin: 0;
			font-size: 0.9rem;
			color: rgb(var(--gray));
			line-height: 1.6;
		}
		.empty {
			text-align: center;
			padding: 2.5em 1em;
			background: var(--surface);
			border: 1px dashed rgb(var(--gray));
			border-radius: var(--radius);
			color: rgb(var(--gray-dark));
		}
		.empty p {
			margin: 0.2em 0;
			font-weight: 700;
		}
		.empty-sub {
			font-weight: 400 !important;
			color: rgb(var(--gray));
		}
		@media (max-width: 860px) {
			.post-grid {
				grid-template-columns: repeat(2, 1fr);
			}
		}
		@media (max-width: 560px) {
			.post-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
</html>
