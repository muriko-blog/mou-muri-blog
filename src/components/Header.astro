---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="brand">
			<img class="brand-mark" src="/muriko.svg" alt="むりこ" width="36" height="36" />
			<span class="brand-name">{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/" class="internal">ホーム</HeaderLink>
			<HeaderLink href="/blog" class="internal">記事一覧</HeaderLink>
			<HeaderLink href="/about" class="internal">運営者について</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: saturate(150%) blur(8px);
		border-bottom: 1px solid rgb(var(--gray-light));
		position: sticky;
		top: 0;
		z-index: 50;
	}
	nav {
		max-width: var(--container);
		margin: 0 auto;
		padding: 0.6em 1em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
		flex-wrap: wrap;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.4em;
		text-decoration: none;
		font-weight: 800;
		font-size: 1.25rem;
		color: rgb(var(--black));
	}
	.brand:hover {
		text-decoration: none;
		color: var(--accent);
	}
	.brand-mark {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		border: 2px solid var(--accent);
		background: var(--accent-soft);
	}
	.internal-links {
		display: flex;
		gap: 0.2em;
	}
	nav :global(a.internal) {
		padding: 0.5em 0.9em;
		color: rgb(var(--gray-dark));
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		transition: background 0.15s ease, color 0.15s ease;
	}
	nav :global(a.internal:hover) {
		background: var(--accent-soft);
		color: var(--accent-dark);
		text-decoration: none;
	}
	nav :global(a.internal.active) {
		background: var(--accent);
		color: #fff;
	}
	@media (max-width: 520px) {
		.brand-name {
			font-size: 1.05rem;
		}
		nav :global(a.internal) {
			padding: 0.4em 0.6em;
			font-size: 0.85rem;
		}
	}
</style>
